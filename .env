#/-------------------[DOTENV_PUBLIC_KEY]--------------------/
#/            public-key encryption for .env files          /
#/       [how it works](https://dotenvx.com/encryption)     /
#/----------------------------------------------------------/

#/----------------------------------------------------------/
#/                                                          /
#/                🌟 REQUIRED CONFIGURATION 🌟             /
#/                                                          /
#/----------------------------------------------------------/

# @developers: please prefix with LX_ for consistency and to allow easier integration into existing systems
#     in Swift 🐦: use ProcessInfo.processInfo.environment["NAME"]
#     in (Objective) C/C++ 🛠️: use getenv("NAME") to access them during run time.
#          ⮱ To use `getenv`, include `<stdlib.h>` in your code.
#     in Rust 🦀: use std::env to access them during run time, e.g. env::var("LX_KEYCLOAK_PUBLIC_KEY")
#     in Typescript ✨: access via AppConfig, e.g. appConfig.get("LX_KEYCLOAK_URL")
#          ⮱ make sure that they are exported via APP_CONFIG_EXPORT_TO_FRONTEND_PREFIXES!!

#LX_KEYCLOAK_URL=https://keycloak.url.com/auth
#LX_KEYCLOAK_CLIENT_ID=client-id
#LX_KEYCLOAK_REALM=REALM
LX_NO_AUTH=true

LX_WORKER_LISTEN_ON=0.0.0.0
LX_WORKER_LISTEN_PORT=1337
LX_JWT_ROLE=
LX_ALLOWED_CORS_ORIGIN=localhost:1337

#/----------------------------------------------------------/
#/  🚀 Build-Time Constants                                 /
#/----------------------------------------------------------/
#/  These values are embedded directly into the frontend    /
#/  during the build process. No LX_ prefix is required.    /
#/  Use the VITE_ prefix for frontend-specific constants.   /
#/----------------------------------------------------------/

VITE_LX_API_PREFIX=api
VITE_LX_PRIVATE_API_PREFIX=private
VARIABLE_PREFIX=LX_
LIST_SEPERATOR=,
APP_CONFIG_EXPORT_TO_FRONTEND_PREFIXES=LX_KEYCLOAK,VITE_LX,LX_NO_
APP_CONFIG_EXPORT_TO_FRONTEND_EXCLUDE=