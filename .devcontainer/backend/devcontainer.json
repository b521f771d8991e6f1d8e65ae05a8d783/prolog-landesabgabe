{
    "build": {
        "target": "development",
        "dockerfile": "../../Dockerfile",
        "context": "../.."
    },
    "customizations": {
        "vscode": {
            "terminal.integrated.shell.linux": "/bin/zsh",
            "extensions": [
                "bbenoist.nix",
                "ms-vscode.cmake-tools",
                "ms-azuretools.vscode-docker",
                "llvm-vs-code-extensions.vscode-clangd",
                "streetsidesoftware.code-spell-checker",
                "ms-vscode.hexeditor",
                "swiftlang.swift-vscode",
                "james-yu.latex-workshop",
                "arthurwang.vsc-prolog",
                "rust-lang.rust-analyzer",
                "ms-vscode.makefile-tools",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint"
            ]
        }
    },
    "runArgs": [
        "--userns=keep-id:uid=1000,gid=1000"
    ],
    "containerUser": "root",
    "workspaceFolder": "/workspace/prolog-landesabgabe",
    "mounts": [
        "type=bind,source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/root/.ssh,readonly",
        "type=bind,source=${localWorkspaceFolder},target=/workspace/prolog-landesabgabe"
        //"type=bind,source=${localEnv:HOME}${localEnv:USERPROFILE}/.gnupg,target=/root/.gnupg,readonly"
    ]
}