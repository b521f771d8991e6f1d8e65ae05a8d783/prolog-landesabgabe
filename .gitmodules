[submodule "Dependencies/googletest"]
	path = Dependencies/googletest
	url = https://github.com/google/googletest
	fetchRecurseSubmodules = true
	ignore = all
[submodule "Dependencies/boost"]
	path = Dependencies/boost
	url = https://github.com/boostorg/boost
	fetchRecurseSubmodules = true
	ignore = all
[submodule "Dependencies/swi-prolog"]
	path = Dependencies/swi-prolog
	url = https://github.com/SWI-Prolog/swipl
	fetchRecurseSubmodules = true
	ignore = all
[submodule "Dependencies/zlib"]
	path = Dependencies/zlib
	url = https://github.com/madler/zlib
	fetchRecurseSubmodules = true
	ignore = all
[submodule "Dependencies/nixpkgs"]
	path = Dependencies/nixpkgs
	url = https://github.com/NixOS/nixpkgs
	fetchRecurseSubmodules = true
	ignore = all
[submodule "Dependencies/xctest"]
	path = Dependencies/xctest
	url = https://github.com/swiftlang/swift-corelibs-xctest
	fetchRecurseSubmodules = true
	ignore = all
[submodule "Dependencies/flake-utils"]
	path = Dependencies/flake-utils
	url = https://github.com/numtide/flake-utils
	fetchRecurseSubmodules = true
	ignore = all
