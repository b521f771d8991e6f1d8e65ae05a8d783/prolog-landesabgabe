{
    "cmake.configureOnOpen": false,
    "latex-workshop.latex.outDir": "%TMPDIR%",
    "editor.rulers": [
        80
    ],
    "git.autofetch": "all",
    "cmake.automaticReconfigure": false,
    "git.enableCommitSigning": true,
    "files.exclude": {
        "**/.DS_Store": false,
        "**/.git": false,
        "**/.hg": false,
        "**/.svn": false,
        "**/CVS": false,
        "**/Thumbs.db": false
    },
    "cSpell.words": [
        "endforeach"
    ],
    "clangd.arguments": [
        "--compile-commands-dir=/workspace/out/build/debug-x86-64-unknown-linux-gnu"
    ],
    "C_Cpp.intelliSenseEngine": "disabled",
    "prettier.configPath": "/workspace/Sources/lxui/.prettierrc.mjs",
    "eslint.workingDirectories": [
        "/workspace/Sources/lxui/"
    ]
}