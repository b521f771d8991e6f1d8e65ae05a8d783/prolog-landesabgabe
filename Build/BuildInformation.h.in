#ifndef BUILD_INFORMATION_H
#define BUILD_INFORMATION_H

#ifdef __cplusplus
extern "C"
{
#endif

  extern const char *getBuildType(void);
  extern const char *getGitHash(void);
  extern unsigned getBuildYear(void);
  extern unsigned getBuildMonth(void);
  extern unsigned getBuildDay(void);

#ifdef __cplusplus
}

#include <string_view>
#include <string>

namespace BuildInformation
{

// clang-format off

constexpr const char* gitHash("@GIT_HASH@");
constexpr const char* gitBranch("@GIT_BRANCH@");
constexpr bool isDirty(@GIT_DIRTY@);

constexpr const char* buildType("@BUILD_TYPE@");

constexpr unsigned buildYear(@BUILD_YEAR@);
constexpr unsigned buildMonth(0x@BUILD_MONTH@);
constexpr unsigned buildDay(0x@BUILD_DAY@);

class VersionString {
private:
  std::string_view gitHash;
  std::string_view gitBranch;
  bool isDirty;

  std::string_view buildType;
  
  unsigned buildYear, buildMonth, buildDay;

public:
  constexpr VersionString(std::string_view gitHash,
                         std::string_view gitBranch,
                         bool isDirty,
                         std::string_view buildType,
                         unsigned buildYear,
                         unsigned buildMonth,
                         unsigned buildDay)
  : gitHash(gitHash)
  , gitBranch(gitBranch)
  , isDirty(isDirty)
  , buildType(buildType)
  , buildYear(buildYear)
  , buildMonth(buildMonth)
  , buildDay(buildDay)
  { }

  constexpr unsigned getBuildYear(void) noexcept {
    return this->buildYear;
  }

  constexpr unsigned getBuildMonth(void) noexcept {
    return this->buildMonth;
  }

  constexpr unsigned getBuildDay(void) noexcept {
    return this->buildDay;
  }

  constexpr static VersionString getCurrentVersion(void) noexcept {
    return VersionString{
      BuildInformation::gitHash,
      BuildInformation::gitBranch,
      BuildInformation::isDirty,
      BuildInformation::buildType,
      BuildInformation::buildYear,
      BuildInformation::buildMonth,
      BuildInformation::buildDay
    };
  }

  #if __cplusplus >= 202002L
    // C++20 (and later) code
    constexpr
  #else
    inline
  #endif
  operator std::string(void) const noexcept {
    return std::to_string(this->buildYear)
      + '.' + std::to_string(this->buildMonth)
      + '.' + std::to_string(this->buildDay)
      + '-' + std::string(this->gitHash)
      + (this->isDirty ? std::string("-dirty-") : std::string(""))
      + '-' + std::string(this->gitBranch)
      + '(' + std::string(this->buildType) + ')';
  }

  #if __cplusplus >= 202002L
    constexpr
  #else
    inline
  #endif
  std::string toString(void) const noexcept {
    return *this;
  }
};

#if __cplusplus >= 202002L
  constexpr
#else
  inline
#endif
std::string getCurrentVersionAsString(void) {
  return VersionString::getCurrentVersion().toString();
}

// clang-format on

} // namespace BuildInformation

#endif

#endif