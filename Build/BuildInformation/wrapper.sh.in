#! /usr/bin/env zsh

export "CC=@CMAKE_C_COMPILER@"
export "CFLAGS=@CMAKE_C_FLAGS@ @EXTERNAL_PROJECT_OPTIONS@"

export "CXX=@CMAKE_CXX_COMPILER@"
export "CXXFLAGS=@CMAKE_CCC_FLAGS@ @EXTERNAL_PROJECT_OPTIONS@"

export "OBJC=@CMAKE_OBJC_COMPILER@"
export "OBJCFLAGS=@CMAKE_OBJC_FLAGS@ @EXTERNAL_PROJECT_OPTIONS@"

export "OBJCXX=@CMAKE_OBJCXX_COMPILER@"
export "OBJCXXFLAGS=@CMAKE_OBJCXX_FLAGS@ @EXTERNAL_PROJECT_OPTIONS@"

eval "$*"